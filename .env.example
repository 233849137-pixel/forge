# Forge open-source defaults
# Copy this file to `.env.local` when you want to enable local-only capabilities.

# Data source mode:
# - demo: always use the bundled demo database
# - local: always use your own local database
# - auto: use data/forge.db if it exists, otherwise fall back to data/forge-demo.db
FORGE_DATA_MODE=demo

# Optional: explicitly point Forge at your own SQLite database.
# FORGE_DB_PATH=/absolute/path/to/forge.db

# Optional: re-enable project-specific "打开调试页" buttons.
# Supports JSON object or JSON array mappings.
# Example object:
# NEXT_PUBLIC_FORGE_DEBUG_WORKSPACE_MAPPINGS={"\/absolute\/path\/to\/workspace":"http://localhost:5000/"}
# Example array:
# NEXT_PUBLIC_FORGE_DEBUG_WORKSPACE_MAPPINGS=[{"workspacePath":"/absolute/path/to/workspace","debugUrl":"http://localhost:5000/"}]

# Optional: allow real-skill hydration instead of OSS-safe demo behavior.
# FORGE_ENABLE_REAL_SKILLS=1

# Optional: connect an Obsidian vault for knowledge / note features.
# FORGE_OBSIDIAN_VAULT_PATH=/absolute/path/to/your/obsidian-vault
# FORGE_OBSIDIAN_CLI_BIN=obsidian-cli
# FORGE_OBSIDIAN_CLI_TIMEOUT_MS=3000

# Optional: connect Nano CEO / NanoClaw as the execution backend.
# FORGE_NANO_EXEC_PROVIDER=Nano CEO
# FORGE_NANO_EXEC_BACKEND=NanoClaw
# FORGE_NANO_EXEC_BIN=nanoclaw
# FORGE_NANO_HEALTHCHECK_COMMAND=nanoclaw health --json
# FORGE_NANO_MANAGE_COMMAND=nanoclaw manage --payload "{payloadFile}"
